# Copy this file to ".env" and fill in YOUR PostgreSQL password.
# DO NOT commit the real .env file to git.

DATABASE_URL=postgresql://talentiq_user:CHANGE_ME@localhost:5432/talentiq

# CORS — comma-separated list of frontend origins allowed to call the API.
# Your Vite dev server runs at 5173 by default.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI API key used by POST /api/ai/resource-matches.
# Keep this backend-only. Do not put it in the frontend .env.
OPENAI_API_KEY=sk-...
# Model used by POST /api/ai/resource-matches. OPENAI_STAGE1_MODEL is also
# supported as an optional per-environment override.
OPENAI_MODEL=gpt-5.2
