# Docker Compose configuration for TalentIQ.
# Copy this file to ".env" (next to docker-compose.yml) and adjust as needed.
# `docker compose` automatically reads a ".env" file from this directory.
# NOTE: this is separate from talentiq-backend/.env and talentiq-Frontend/.env.

# --- PostgreSQL ---
POSTGRES_USER=talentiq
POSTGRES_PASSWORD=talentiq
POSTGRES_DB=talentiq

# --- Host port mappings (host:container) ---
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Backend AI matching (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
